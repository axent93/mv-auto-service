{
  "name": "mv-servis",
  "version": "1.0.0",
  "private": true,
  "description": "Privatna PWA aplikacija za evidenciju auto mehanicarskog servisa",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint . --max-warnings=0",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed:default-user": "cross-env NODE_OPTIONS=--no-deprecation payload run ./src/scripts/seed-default-super-user.ts",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.78.0",
    "@payloadcms/next": "3.78.0",
    "@payloadcms/richtext-lexical": "3.78.0",
    "@payloadcms/translations": "3.78.0",
    "@payloadcms/storage-s3": "3.78.0",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "next": "16.1.6",
    "payload": "3.78.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10"
  },
  "packageManager": "pnpm@10.26.1+sha512.664074abc367d2c9324fdc18037097ce0a8f126034160f709928e9e9f95d98714347044e5c3164d65bd5da6c59c6be362b107546292a8eecb7999196e5ce58fa"
}
